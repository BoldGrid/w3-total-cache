{
    "scripts": {
        "install:deps": "composer install --no-interaction --prefer-dist -o && yarn install --frozen-lockfile",
        "css-lint": "stylelint \"**/*.{css,scss}\" --ignore-path .stylelintignore",
        "css-lint-fix": "stylelint \"**/*.{css,scss}\" --ignore-path .stylelintignore --fix",
        "js-lint": "prettier-eslint **/*.js --ignore **/build/** --ignore **/vendor/** --ignore **/*.min.js --list-different",
        "js-lint-fix": "prettier-eslint **/*.js --ignore **/build/** --ignore **/vendor/** --ignore **/*.min.js --write",
        "php-lint": "find . -name vendor -prune -o -name node_modules -prune -o -name '*.php' -exec php -lf {} \\; > /dev/null",
        "upgrade:deps": "composer update --with-all-dependencies && yarn upgrade",
        "update:since": "bash bin/update-since-versions.sh"
    },
    "devDependencies": {
        "@boldgrid/wordpress-tag-sync": "^1.3.0",
        "@wordpress/eslint-plugin": "^18",
        "@wordpress/stylelint-config": "^23.40.0",
        "eslint": "^8.57.1",
        "eslint-plugin-html": "^8.1.1",
        "prettier-eslint": "^16.3.0",
        "prettier-eslint-cli": "^8.0.1",
        "stylelint": "^16.8.2"
    },
    "type": "commonjs"
}
